<!DOCTYPE html>
<html lang="uk">

<head>
    <meta charset="UTF-8">
    <title>Налаштування серверу</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="/styles/guild.css">
    
    <!-- <%- include('layout/head') %> -->
</head>

<body>
    <div id="app" v-cloak>
        <header-component></header-component>


        <div class="main-content">
            <div class="page-container">
                <div class="guild-header-container">
                    <div class="d-flex align-items-center">
                        <div class="guild-icon me-3" v-if="guild && guild.icon">
                            <img :src="'https://cdn.discordapp.com/icons/' + guild.id + '/' + guild.icon + '.png'"
                                alt="Guild Icon">
                        </div>
                        <div v-if="guild">
                            <h2>{{ guild.name }}</h2>
                            <small class="text-muted">ID: {{ guildId }}</small>
                        </div>
                    </div>
                    <button class="back-btn" @click="goBack">
                        {{ t('guild.back')}}
                    </button>
                </div>

                <div class="progress-container" v-if="isLoading">
                    <div class="progress-bar" :style="{width: loadingProgress + '%'}"></div>
                </div>

                <div v-if="isLoading && loadingProgress < 100" class="text-center py-3">
                    <div class="d-flex justify-content-center align-items-center">
                        <div class="loading-spinner"></div>
                        <p>Завантаження... {{ Math.round(loadingProgress) }}%</p>
                    </div>
                </div>

                <div v-else-if="error" class="alert alert-danger">
                    {{ error }}
                    <button @click="loadGuildData" class="btn btn-sm btn-outline-secondary ms-2">Спробувати
                        знову</button>
                </div>

                <div v-else class="guild-settings">
                    <div class="settings-tabs">
                        <button class="tab-btn" :class="{active: activeTab === 'main'}" @click="activeTab = 'main'">
                            {{ t('guild.head_buttons.main_settings')}}
                        </button>
                        <button class="tab-btn" :class="{active: activeTab === 'logging'}"
                            @click="activeTab = 'logging'">
                            {{ t('guild.head_buttons.logging')}}
                        </button>
                        <button class="tab-btn" :class="{active: activeTab === 'verification'}"
                            @click="activeTab = 'verification'">
                            {{ t('guild.head_buttons.verification')}}
                        </button>
                        <button class="tab-btn" :class="{active: activeTab === 'backups'}"
                            @click="activeTab = 'backups'">
                            {{ t('guild.head_buttons.backups')}}
                        </button>
                    </div>

                    <!-- Основні налаштування -->
                    <div class="tab-content" :class="{active: activeTab === 'main'}">
                        <div class="settings-card">
                            <h4 class="mb-4"><i class="fa-solid fa-gear"></i>{{ t('guild.main_settings.title')}}</h4>

                            <div class="mb-3">
                                <label class="form-label d-flex align-items-center justify-content-between">
                                    <span>{{ t('guild.main_settings.language')}}</span>
                                    <select v-model="mainSettings.language" class="form-select w-auto">
                                        <option value="uk">Українська</option>
                                        <option value="en">English</option>
                                    </select>
                                </label>
                            </div>

                            <div class="mb-3">
                                <label class="form-label d-flex align-items-center justify-content-between">
                                    <span>{{ t('guild.main_settings.people_ban')}}</span>
                                    <label class="toggle-switch">
                                        <input type="checkbox" v-model="mainSettings.autoMod">
                                        <span class="slider"></span>
                                    </label>
                                </label>
                            </div>

                            <div class="mb-4">
                                <label class="form-label mb-2">{{ t('guild.main_settings.whitelist')}}</label>
                                <div class="whitelist-roles">
                                    <div class="d-flex mb-2 gap-2">
                                        <input type="search" class="form-control form-control-sm"
                                            :placeholder="t('guild.main_settings.search_placeholder')" v-model="roleQuery" aria-label="Пошук ролі">
                                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                            @click="roleQuery = ''" title="Очистити пошук">✕</button>
                                    </div>

                                    <div v-if="rolesLoading" class="text-center py-2">
                                        <div class="loading-spinner"></div>
                                        <div class="small mt-1">Завантаження ролей...</div>
                                    </div>

                                    <div v-else-if="filteredRoles.length === 0" class="text-muted text-center py-2">
                                        {{ t('guild.main_settings.no_roles')}}
                                    </div>

                                    <div v-else class="roles-list">
                                        <label class="role-item" v-for="role in filteredRoles" :key="role.id">
                                            <input type="checkbox" :id="'role-' + role.id" v-model="whitelistRoles"
                                                :value="role.id" class="form-check-input me-2" />
                                            <span class="role-swatch"
                                                :style="{backgroundColor: '#' + (role.color ? role.color.toString(16).padStart(6,'0') : '888888')}"></span>
                                            <span class="role-name">{{ role.name }}</span>
                                            <small class="text-muted ms-auto"
                                                v-if="role.members && role.members > 0">({{ role.members }} )</small>
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <button @click="saveMainSettings" class="btn btn-primary" :disabled="isSaving">
                                <span v-if="isSaving" class="d-flex align-items-center">
                                    <span class="loading-spinner"></span>
                                    <span>{{ t('guild.main_settings.saving') }}</span>
                                </span>
                                <span v-else>{{ t('guild.main_settings.save_settings')}}</span>
                            </button>

                            <div v-if="successMessage" class="alert alert-success mt-3">
                                {{ successMessage }}
                            </div>
                        </div>
                    </div>

                    <div class="tab-content" :class="{active: activeTab === 'logging'}">
                        <div class="settings-card">
                            <h4 class="mb-4"><i class="fa-solid fa-layer-group"> </i>{{ t('guild.logging.title')}}</h4>

                            <div class="mb-3">
                                <label class="form-label">{{ t('guild.logging.current_webhook')}}</label>
                                <div v-if="currentWebhook" class="mb-2 p-3 bg-dark rounded">
                                    <div><strong>{{ t('guild.logging.webhook_data.name')}}</strong> {{ currentWebhook.name || 'Без назви' }}</div>
                                    <div><strong>{{ t('guild.logging.webhook_data.channel')}}</strong> {{ getChannelName(currentWebhook.channel_id) }}</div>
                                    <div><strong>ID:</strong> {{ currentWebhook.id }}</div>
                                </div>
                                <div v-else class="text-muted mb-2">
                                    {{ t('guild.logging.not_setup')}}
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">{{ t('guild.logging.choose_webhook')}}</label>
                                <select v-model="loggingSettings.webhookId" class="form-select" :disabled="isSaving">
                                    <option value="">-- {{ t('guild.logging.choose_webhook')}} --</option>
                                    <option v-for="webhook in webhooks" :value="webhook.id" :key="webhook.id">
                                        {{ webhook.name || 'Без назви' }} (Канал: {{ getChannelName(webhook.channel_id)
                                        }})
                                    </option>
                                </select>
                            </div>

                            <div v-if="loggingSettings.webhookId" class="mb-3">
                                <label class="form-label">{{ t('guild.logging.webhook_data.url')}}</label>
                                <div class="input-group">
                                    <input :type="showWebhookUrl ? 'text' : 'password'" class="form-control"
                                        :value="getWebhookUrl(loggingSettings.webhookId)" readonly>
                                    <button @click="copyWebhookUrl(loggingSettings.webhookId)"
                                        class="btn btn-outline-secondary" type="button" title="Копіювати">
                                        <i class="fas fa-copy"></i>
                                    </button>
                                    <button @click="showWebhookUrl = !showWebhookUrl" class="btn btn-outline-secondary"
                                        type="button" :title="showWebhookUrl ? 'Приховати' : 'Показати'">
                                        <i :class="showWebhookUrl ? 'fas fa-eye-slash' : 'fas fa-eye'"></i>
                                    </button>
                                </div>
                            </div>

                            <button @click="saveLoggingSettings" class="btn btn-primary" :disabled="isSaving">
                                <span v-if="isSaving" class="d-flex align-items-center">
                                    <span class="loading-spinner"></span>
                                    <span>{{ t('guild.main_settings.saving') }}</span>
                                </span>
                                <span v-else>{{ t('guild.main_settings.save_settings') }}</span>
                            </button>

                            <div v-if="successMessage" class="alert alert-success mt-3">
                                {{ successMessage }}
                            </div>
                        </div>
                    </div>

                    <div class="tab-content" :class="{active: activeTab === 'verification'}">
                        <div class="settings-card">
                            <h4 class="mb-4"><i class="fas fa-user-check me-2"></i>{{ t('guild.verification.title') }}</h4>

                            <!-- Форма налаштувань -->
                            <div class="settings-form">
                                <div class="mb-3">
                                    <label class="form-label">{{ t('guild.verification.verifed_members')}}</label>
                                    <select v-model="verificationSettings.verifiedRole" class="form-select">
                                        <option value="">{{ t('guild.verification.choose_role')}}</option>
                                        <option v-for="role in availableRoles" :value="role.id"
                                            :key="'verified-'+role.id"
                                            :selected="role.id === verificationSettings.verifiedRole">
                                            {{ role.name }}
                                        </option>
                                    </select>
                                    <div v-if="verificationSettings.verifiedRole" class="mt-2">
                                        <span class="badge"
                                            :style="{backgroundColor: '#' + getRoleColor(verificationSettings.verifiedRole)}">
                                            {{ getRoleName(verificationSettings.verifiedRole) }}
                                        </span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">{{ t('guild.verification.new_members')}}</label>
                                    <select v-model="verificationSettings.unverifiedRole" class="form-select">
                                        <option value="">{{ t('guild.verification.choose_role')}}</option>
                                        <option v-for="role in availableRoles" :value="role.id"
                                            :key="'unverified-'+role.id"
                                            :selected="role.id === verificationSettings.unverifiedRole">
                                            {{ role.name }}
                                        </option>
                                    </select>
                                    <div v-if="verificationSettings.unverifiedRole" class="mt-2">
                                        <span class="badge"
                                            :style="{backgroundColor: '#' + getRoleColor(verificationSettings.unverifiedRole)}">
                                            {{ getRoleName(verificationSettings.unverifiedRole) }}
                                        </span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">{{ t('guild.verification.channel')}}</label>
                                    <select v-model="verificationSettings.verificationChannel" class="form-select">
                                        <option value=""> {{ t('guild.verification.choose_channel')}} </option>
                                        <option v-for="channel in textChannels" :value="channel.id"
                                            :key="'channel-'+channel.id"
                                            :selected="channel.id === verificationSettings.verificationChannel">
                                            #{{ channel.name }}
                                        </option>
                                    </select>
                                    <div v-if="verificationSettings.verificationChannel" class="mt-2">
                                        <span class="badge bg-secondary">
                                            {{ getChannelName(verificationSettings.verificationChannel) }}
                                        </span>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label d-flex align-items-center justify-content-between">
                                        <span>{{ t('guild.verification.enable_captcha') }}</span>
                                        <label class="toggle-switch">
                                            <input type="checkbox" v-model="verificationSettings.captchaEnabled"
                                                :checked="verificationSettings.captchaEnabled">
                                            <span class="slider"></span>
                                        </label>
                                    </label>
                                </div>

                                <button @click="saveVerificationSettings" class="btn btn-primary" :disabled="isSaving">
                                    <span v-if="isSaving" class="d-flex align-items-center">
                                        <span class="loading-spinner me-2"></span>
                                        <span>{{ t('guild.main_settings.saving')}}</span>
                                    </span>
                                    <span v-else>
                                        <i class="fas fa-save me-1"></i>
                                        {{ t('guild.main_settings.save_settings')}}
                                    </span>
                                </button>

                                <div v-if="successMessage" class="alert alert-success mt-3">
                                    {{ successMessage }}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-content" :class="{active: activeTab === 'backups'}">
                        <div class="settings-card">
                            <h4 class="mb-4"><i class="fa-solid fa-gear"></i> {{ t('guild.backups.title')}}</h4>

                            <div v-if="!hasAdminPermissions" class="alert alert-danger mb-4">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <span v-html="t('guild.backups.no_perms')"></span>
                                
                            </div>
                            <!-- 
                            <fieldset :disabled="!hasAdminPermissions">
                                <div class="mb-4">
                                    <label class="form-label"> -->
                            <!-- Текст і кнопка в ряд -->
                            <!-- <div class="d-flex align-items-center justify-content-between mb-2">
                                        <span>Автоматичні резервні копіювання:</span>
                                        <select 
                                            v-model="mainSettings.backupInterval"
                                            class="form-select w-auto"
                                            :disabled="!mainSettings.isPremium"
                                        >
                                            <option value="off">Вимкнено</option>
                                            <option value="1h">1 година</option>
                                            <option value="6h">6 годин</option>
                                            <option value="12h">12 годин</option>
                                            <option value="1d">1 день</option>
                                            <option value="7d">7 днів</option>
                                        </select>
                                        </div>

                                      Повідомлення під ними -->
                            <!-- <div v-if="!mainSettings.isPremium" class="alert alert-warning d-flex align-items-center">
                                        <i class="fas fa-info-circle me-2"></i>
                                        Ця функція доступна лише для преміум-гільдій
                                        </div>
                                    </label>
                                    </div>

                            </fieldset> -->

                            <!-- Секція для відображення бекапів -->
                            <div class="backups-section mt-4">
                                <h5 class="mb-3"><i class="fas fa-database"></i> {{ t('guild.backups.backups_list')}}</h5>

                                <div v-if="backups.loading" class="text-center py-4">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">{{ t('guild.backups.loading')}}</span>
                                    </div>
                                </div>

                                <div v-if="!backups.loading && !backups.list.length" class="alert alert-info">
                                    <i class="fas fa-info-circle"></i> {{ t('guild.backups.no_backups')}}
                                </div>

                                <div v-else-if="backups.list.length" class="table-responsive">
                                    <table class="table table-hover backups-table">
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>{{ t('guild.backups.date')}}</th>
                                                <th>{{ t('guild.backups.actions')}}</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr v-for="backup in backups.list" :key="backup._id || backup.id">
                                                <td>{{ backup._id || backup.id }}</td>
                                                <td>{{ formatDate(backup.createdAt) }}</td>
                                                <td>
                                                    <button @click="confirmRestoreBackup(backup._id || backup.id)"
                                                        class="btn btn-sm btn-success me-2" title="Відновити"
                                                        :disabled="!hasAdminPermissions || restoringId === backup._id || restoringId === backup.id || (cooldownId === backup._id || cooldownId === backup.id)">

                                                        <template v-if="restoringId === (backup._id || backup.id)">
                                                            <i class="fas fa-spinner fa-spin"></i> {{ t('guild.backups.recovery')}}
                                                        </template>
                                                        <template v-else-if="cooldownId === (backup._id || backup.id)">
                                                            <i class="fas fa-clock"></i> {{ t('guild.backups.wait')}} {{ cooldownTime }}с
                                                        </template>
                                                        <template v-else>
                                                            <i class="fas fa-undo"></i> {{ t('guild.backups.restore')}}
                                                        </template>
                                                    </button>

                                                    <div v-if="cooldownId === (backup._id || backup.id)"
                                                        class="text-muted small mt-1">
                                                        <span v-html="t('guild.backups.cooldown')">
                                                        </span>
                                                    </div>

                                                    <button @click="confirmDeleteBackup(backup._id || backup.id)"
                                                        class="btn btn-sm btn-danger" title="{{ t('guild.backups.delete')}}"
                                                        :disabled="!hasAdminPermissions">
                                                        <i class="fas fa-trash"></i> {{ t('guild.backups.delete')}}
                                                    </button>
                                                </td>
                                            </tr>

                                        </tbody>
                                    </table>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <button @click="confirmCreateBackup" class="btn btn-primary"
                                        :disabled="backups.creating || !hasAdminPermissions">
                                        <span v-if="backups.creating" class="d-flex align-items-center">
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                            {{ t('guild.backups.creating')}}
                                        </span>
                                        <span v-else>
                                            <i class="fas fa-plus-circle me-2"></i>{{ t('guild.backups.create')}}
                                        </span>
                                    </button>

                                    <div class="text-muted small">
                                        {{ t('guild.backups.all_backups')}} {{ backups.list.length }}
                                    </div>
                                </div>
                            </div>

                            <div v-if="successMessage" class="alert alert-success mt-3">
                                {{ successMessage }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <footer-component v-if="!isLoading || loadingProgress >= 100" class="main-footer" />
    </div>

    <%- include('layout/scripts') %>
    
    <script type="module" src="/frontend/guild.js"></script>

</body>

</html>