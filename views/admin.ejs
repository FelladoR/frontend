<!DOCTYPE html>
<html lang="uk">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AntiLink Admin | Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/styles/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://unpkg.com/@simplewebauthn/browser/dist/bundle/index.umd.min.js"></script>
</head>

<body class="bg-[#0b0b0e] text-[#e2e2e4] font-sans selection:bg-indigo-500/30">

    <div class="flex min-h-screen">
        <%- include('layout/admin-side') %>

            <main class="flex-1 flex flex-col">
                <header
                    class="h-20 bg-[#111116]/50 backdrop-blur-xl border-b border-white/5 flex items-center justify-between px-10 sticky top-0 z-50">
                    <div class="flex items-center gap-4">
                        <div
                            class="w-2 h-2 rounded-full bg-indigo-500 shadow-[0_0_10px_rgba(99,102,241,0.8)] animate-pulse">
                        </div>
                        <span class="text-sm font-medium text-white/70">Вітаємо, <span class="text-white font-bold">
                                <%= user.username %>
                            </span></span>
                    </div>

                    <div class="flex items-center gap-6">
                        <% if (user.passkeyVerified) { %>
                            <div
                                class="flex items-center gap-2 px-3 py-1.5 bg-emerald-500/10 border border-emerald-500/20 rounded-full">
                                <i class="fas fa-check-double text-emerald-500 text-[10px]"></i>
                                <span
                                    class="text-[10px] font-black text-emerald-500 uppercase tracking-widest">Secured</span>
                            </div>
                            <% } %>
                                <a href="/logout"
                                    class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center hover:bg-red-500/20 hover:text-red-500 transition-all border border-white/5">
                                    <i class="fas fa-power-off text-sm"></i>
                                </a>
                    </div>
                </header>

                <div class="p-10 space-y-10">
                    <!-- Кнопка Setup Bitwarden -->
                    <div class="flex justify-end">
                        <button id="registerPasskeyBtn"
                            class="bg-indigo-600 hover:bg-indigo-700 px-5 py-3 rounded-xl font-medium flex items-center gap-2 transition-all">
                            <i class="fas fa-fingerprint"></i>
                            <span>Setup Bitwarden</span>
                        </button>
                    </div>

                    <!-- Статистика -->
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                        <div class="glass-card group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-white/40 text-[11px] font-bold uppercase tracking-widest">Active
                                        Guilds</p>
                                    <h3 class="text-3xl font-black mt-1 tracking-tight">
                                        <%= stats.totalGuilds %>
                                    </h3>
                                </div>
                                <div
                                    class="p-3 bg-indigo-500/10 rounded-2xl text-indigo-500 group-hover:scale-110 transition-transform">
                                    <i class="fas fa-server"></i>
                                </div>
                            </div>
                            <div class="mt-4 flex items-center gap-2 text-[10px] text-emerald-400 font-bold">
                                <i class="fas fa-chart-line"></i> +14 NEW TODAY
                            </div>
                        </div>

                        <div class="glass-card group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-white/40 text-[11px] font-bold uppercase tracking-widest">Total
                                        Members</p>
                                    <h3 class="text-3xl font-black mt-1 tracking-tight">300k</h3>
                                </div>
                                <div
                                    class="p-3 bg-purple-500/10 rounded-2xl text-purple-500 group-hover:scale-110 transition-transform">
                                    <i class="fas fa-users"></i>
                                </div>
                            </div>
                            <div class="mt-4 flex items-center gap-2 text-[10px] text-white/20 font-bold italic">
                                GLOBAL USERBASE
                            </div>
                        </div>

                        <div class="glass-card group border-indigo-500/30">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-white/40 text-[11px] font-bold uppercase tracking-widest">Protection
                                    </p>
                                    <h3 class="text-3xl font-black mt-1 tracking-tight">99.9%</h3>
                                </div>
                                <div class="p-3 bg-indigo-500/20 rounded-2xl text-indigo-400">
                                    <i class="fas fa-shield-check"></i>
                                </div>
                            </div>
                            <div class="mt-4 flex items-center gap-2 text-[10px] text-indigo-400 font-bold">
                                EFFICIENCY RATE
                            </div>
                        </div>

                        <div class="glass-card group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-white/40 text-[11px] font-bold uppercase tracking-widest">Incidents
                                    </p>
                                    <h3 class="text-3xl font-black mt-1 tracking-tight text-red-400">0</h3>
                                </div>
                                <div class="p-3 bg-red-500/10 rounded-2xl text-red-500">
                                    <i class="fas fa-triangle-exclamation"></i>
                                </div>
                            </div>
                            <div class="mt-4 flex items-center gap-2 text-[10px] text-white/20 font-bold uppercase">
                                Last 24 hours
                            </div>
                        </div>
                    </div>

                    <!-- Логи -->
                    <div class="glass-card !p-0 overflow-hidden border-white/10 shadow-2xl">
                        <div class="bg-white/5 px-6 py-4 border-b border-white/5 flex justify-between items-center">
                            <div class="flex items-center gap-3">
                                <div class="flex gap-1.5">
                                    <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></div>
                                    <div class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></div>
                                    <div class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></div>
                                </div>
                                <span
                                    class="text-[10px] font-black text-white/30 uppercase tracking-widest ml-2">Mainframe
                                    Logs</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="pulse-live"></span>
                                <span class="text-[9px] font-bold text-emerald-500 uppercase tracking-tighter">Live
                                    Connection</span>
                            </div>
                        </div>
                        <div
                            class="p-6 h-80 overflow-y-auto font-mono text-xs leading-relaxed text-indigo-300 custom-scrollbar bg-black/20">
                            <p class="mb-1"><span class="text-white/20">18:02:11</span> <span
                                    class="text-emerald-500">[SYSTEM]</span> Kernel initialized successfully.</p>
                            <p class="mb-1"><span class="text-white/20">18:02:12</span> <span
                                    class="text-indigo-500">[AUTH]</span> WebSocket secure connection established.</p>
                            <p class="mb-1"><span class="text-white/20">18:05:44</span> <span
                                    class="text-amber-500">[WARN]</span> Shard #4 latency increased (112ms).</p>
                            <p class="text-white/60 mt-4 flex items-center gap-2">Root access granted. Ready for
                                input<span class="console-cursor"></span></p>
                        </div>
                    </div>
                </div>
            </main>
    </div>

    <script type="module" src="/frontend/admin.js"></script>
    <%- include('layout/admin-main') %>
</body>

</html>