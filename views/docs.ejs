<!DOCTYPE html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Документація</title>

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/styles/main.css"/>
    <link rel="stylesheet" href="/styles/docs.css" />
    <!-- Загальні стилі сайту для узгодженого темного вигляду -->
    <link rel="stylesheet" href="/styles/headerStyles.css" />
    <link rel="stylesheet" href="/styles/guild.css" />
  </head>
  <body>
    <div id="app" v-cloak>
      <header-component></header-component>

      <main class="main-content" role="main">
        <div class="container">
          <div
            class="settings-card"
            style="max-width: 1000px; margin: 28px auto"
          >
            <div class="card-body">
              <h1 class="mb-3">
                <i class="fas fa-shield-alt me-2"></i>{{ t('docs.main_title') }}
              </h1>
              <p class="lead text-muted">
                {{ t('docs.main_description') }}
              </p>

              <div class="note">
                <p>
                  <i class="fas fa-info-circle me-2"></i> {{ t('docs.note_automatic_protection') }}
                </p>
              </div>

              <h2><i class="fas fa-cogs me-2"></i>{{ t('docs.features_title') }}</h2>
              <ul>
                <li>
                  <strong>{{ t('docs.feature_unwanted_users') }}:</strong>
                  {{ t('docs.feature_unwanted_users_desc') }}
                </li>
                <li>
                  <strong>{{ t('docs.feature_warning_system') }}:</strong>
                  {{ t('docs.feature_warning_system_desc') }}
                </li>
                <li>
                  <strong>{{ t('docs.feature_blacklist') }}:</strong>
                  {{ t('docs.feature_blacklist_desc') }}
                </li>
                <li>
                  <strong>{{ t('docs.feature_cross_server') }}:</strong>
                  {{ t('docs.feature_cross_server_desc') }}
                </li>
                <li>
                  <strong>{{ t('docs.feature_crash_bots') }}:</strong>
                  {{ t('docs.feature_crash_bots_desc') }}
                </li>
              </ul>

              <h2><i class="fas fa-user-shield me-2"></i>{{ t('docs.work_concept_title') }}</h2>
              <ol>
                <li>{{ t('docs.concept_step1') }}</li>
                <li>
                  {{ t('docs.concept_step2') }}
                </li>
                <li>
                  <span class="highlight">{{ t('docs.concept_step3_highlight') }}</span> {{ t('docs.concept_step3_text') }}
                </li>
                <li>
                  {{ t('docs.concept_step4') }}
                </li>
              </ol>

              <div class="warning-block">
                <p>
                  <i class="fas fa-exclamation-triangle me-2"></i> {{ t('docs.warning_blacklist') }}
                </p>
              </div>

              <div class="warning-block">
                <p>
                  <i class="fas fa-exclamation-triangle me-2"></i> {{ t('docs.warning_default_settings') }}
                </p>
              </div>

              <h2><i class="fas fa-list-check me-2"></i>{{ t('docs.whitelist_title') }}</h2>

              <div class="note">
                <p>
                  <i class="fas fa-circle-check me-2"></i> {{ t('docs.whitelist_note') }}
                </p>
              </div>

              <ul>
                <li>
                  <strong>{{ t('docs.whitelist_add') }}:</strong>
                  <code>/setup whitelist @{{ t('docs.role') }}</code>
                </li>
                <li>
                  <strong>{{ t('docs.whitelist_remove') }}:</strong>
                  <code>/setup whitelist_remove @{{ t('docs.role') }}</code>
                </li>
              </ul>

              <div class="warning-block">
                <p>
                  <i class="fas fa-exclamation-circle me-2"></i> {{ t('docs.whitelist_warning') }}
                </p>
              </div>

              <p>
                {{ t('docs.whitelist_permissions') }}
              </p>

              <h2>
                <i class="fas fa-sliders-h me-2"></i>{{ t('docs.settings_management_title') }}
              </h2>

              <div class="command">
                <div class="command-icon"><i class="fas fa-terminal"></i></div>
                <div>
                  <code>/settings</code> - {{ t('docs.command_settings') }}

                  <br />
                  <span class="text-muted">{{ t('docs.command_owner_only') }}</span>
                </div>
                <div>
                  <code>/setup</code> - {{ t('docs.command_setup') }}

                  <br />
                  <span class="text-muted">{{ t('docs.command_owner_only') }}</span>
                </div>
              </div>

              <p>
                {{ t('docs.web_panel_text') }}
                <a href="/" class="highlight">{{ t('docs.web_panel_link') }}</a>{{ t('docs.web_panel_text_after') }}
              </p>

              <div class="note">
                <p>
                  <i class="fas fa-lock me-2"></i> <strong>{{ t('docs.note_attention') }}:</strong> {{ t('docs.note_owner_only') }}
                </p>
              </div>

              <h2>
                <i class="fas fa-database me-2"></i>{{ t('docs.user_database_title') }}
              </h2>
              <p>{{ t('docs.user_database_desc') }}</p>
              <ul>
                <li>{{ t('docs.db_field_date') }}</li>
                <li>{{ t('docs.db_field_type') }}</li>
                <li>{{ t('docs.db_field_user_id') }}</li>
                <li>{{ t('docs.db_field_moderator') }}</li>
                <li>{{ t('docs.db_field_notes') }}</li>
              </ul>

              <hr />
            </div>
          </div>
        </div>
      </main>
      <footer-component></footer-component>
    </div>

    <script>

      document
        .querySelectorAll(".settings-card a")
        .forEach((a) => a.setAttribute("rel", "noopener"));


    </script>
    
    <%- include('layout/scripts') %>
    <script type="module" src="/frontend/docs.js"></script>
  </body>
</html>