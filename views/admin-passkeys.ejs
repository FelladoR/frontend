<!-- views/admin-passkeys.ejs -->
<!DOCTYPE html>
<html lang="uk">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AntiLink Admin | Мої passkeys</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/styles/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://unpkg.com/@simplewebauthn/browser/dist/bundle/index.umd.min.js"></script>
</head>

<body class="bg-[#0b0b0e] text-[#e2e2e4] font-sans selection:bg-indigo-500/30">
    <div id="passkey-data" data-required="<%= passkeyRequired %>" style="display: none;"></div>
    <div class="flex min-h-screen">

        <%- include('layout/admin-side') %>

            <!-- Головний контент -->
            <main class="flex-1 flex flex-col">
                <!-- Хедер -->
                <header
                    class="h-20 bg-[#111116]/50 backdrop-blur-xl border-b border-white/5 flex items-center justify-between px-10 sticky top-0 z-50">
                    <div class="flex items-center gap-4">
                        <div
                            class="w-2 h-2 rounded-full bg-indigo-500 shadow-[0_0_10px_rgba(99,102,241,0.8)] animate-pulse">
                        </div>
                        <span class="text-sm font-medium text-white/70">Вітаємо, <span class="text-white font-bold">
                                <%= user.username %>
                            </span></span>
                    </div>

                    <div class="flex items-center gap-6">
                        <% if (user.hasPasskey) { %>
                            <div
                                class="flex items-center gap-2 px-3 py-1.5 bg-emerald-500/10 border border-emerald-500/20 rounded-full">
                                <i class="fas fa-check-double text-emerald-500 text-[10px]"></i>
                                <span
                                    class="text-[10px] font-black text-emerald-500 uppercase tracking-widest">Secured</span>
                            </div>
                            <% } %>
                                <a href="/logout"
                                    class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center hover:bg-red-500/20 hover:text-red-500 transition-all border border-white/5">
                                    <i class="fas fa-power-off text-sm"></i>
                                </a>
                    </div>
                </header>

                <!-- Контент сторінки passkeys -->
                <div class="p-10 space-y-8">
                    <!-- Заголовок і кнопки -->
                    <div class="flex justify-between items-center">
                        <div>
                            <h1 class="text-3xl font-black tracking-tight">Мої passkeys</h1>
                            <p class="text-white/40 text-sm mt-1">Керуйте ключами доступу для вашого акаунту</p>
                        </div>
                        <div class="flex gap-3">
                            <button onclick="registerPasskey()"
                                class="bg-indigo-600 hover:bg-indigo-700 px-5 py-3 rounded-xl font-medium flex items-center gap-2 transition-all">
                                <i class="fas fa-plus"></i>
                                <span>Додати passkey</span>
                            </button>

                        </div>
                    </div>

                    <!-- Статистика -->
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                        <div class="glass-card group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-white/40 text-[11px] font-bold uppercase tracking-widest">Всього
                                        ключів
                                    </p>
                                    <h3 class="text-3xl font-black mt-1 tracking-tight">
                                        <%= stats.total %>
                                    </h3>
                                </div>
                                <div
                                    class="p-3 bg-indigo-500/10 rounded-2xl text-indigo-500 group-hover:scale-110 transition-transform">
                                    <i class="fas fa-key"></i>
                                </div>
                            </div>
                        </div>

                        <div class="glass-card group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-white/40 text-[11px] font-bold uppercase tracking-widest">Активні</p>
                                    <h3 class="text-3xl font-black mt-1 tracking-tight">
                                        <%= stats.active %>
                                    </h3>
                                </div>
                                <div
                                    class="p-3 bg-emerald-500/10 rounded-2xl text-emerald-500 group-hover:scale-110 transition-transform">
                                    <i class="fas fa-check-circle"></i>
                                </div>
                            </div>
                            <div class="mt-4 flex items-center gap-2 text-[10px] text-emerald-400 font-bold">
                                <i class="fas fa-circle"></i> ВСІ АКТИВНІ
                            </div>
                        </div>

                        <div class="glass-card group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-white/40 text-[11px] font-bold uppercase tracking-widest">Останній
                                        ключ
                                    </p>
                                    <h3 class="text-sm font-black mt-1 tracking-tight">
                                        <%= stats.lastAdded %>
                                    </h3>
                                </div>
                                <div
                                    class="p-3 bg-purple-500/10 rounded-2xl text-purple-500 group-hover:scale-110 transition-transform">
                                    <i class="fas fa-calendar"></i>
                                </div>
                            </div>
                        </div>

                        <div class="glass-card group border-indigo-500/30">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-white/40 text-[11px] font-bold uppercase tracking-widest">Останнє
                                        використання</p>
                                    <h3 class="text-sm font-black mt-1 tracking-tight">
                                        <%= stats.lastUsed %>
                                    </h3>
                                </div>
                                <div class="p-3 bg-amber-500/10 rounded-2xl text-amber-500">
                                    <i class="fas fa-clock"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Інформація про безпеку -->
                    <div class="bg-indigo-500/10 border border-indigo-500/20 rounded-2xl p-6 flex items-start gap-4">
                        <div class="p-3 bg-indigo-500/20 rounded-xl">
                            <i class="fas fa-shield-halved text-indigo-500 text-xl"></i>
                        </div>
                        <div>
                            <h3 class="font-bold text-lg">Як працюють passkeys?</h3>
                            <p class="text-white/60 text-sm mt-1">Passkeys — це сучасна заміна паролям. Ваш пристрій
                                створює
                                унікальний криптографічний ключ, який зберігається тільки у вашому менеджері паролів
                                (Bitwarden). Сервер зберігає лише публічну частину ключа, що робить злом неможливим.</p>
                        </div>
                    </div>

                    <!-- Список passkeys -->
                    <div class="glass-card !p-0 overflow-hidden border-white/10">
                        <div class="bg-white/5 px-6 py-4 border-b border-white/5 flex justify-between items-center">
                            <h3 class="font-bold">Ваші passkeys</h3>
                            <span class="text-xs text-white/40">Натисніть на ключ для копіювання ID</span>
                        </div>

                        <% if (passkeys.length===0) { %>
                            <div class="p-12 text-center">
                                <div
                                    class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-4">
                                    <i class="fas fa-fingerprint text-3xl text-white/20"></i>
                                </div>
                                <h3 class="text-xl font-bold mb-2">Ще немає passkeys</h3>
                                <p class="text-white/40 mb-6">Додайте ваш перший passkey для підвищення безпеки</p>
                                <button onclick="registerPasskey()"
                                    class="bg-indigo-600 hover:bg-indigo-700 px-6 py-3 rounded-xl font-medium inline-flex items-center gap-2">
                                    <i class="fas fa-plus"></i>
                                    <span>Додати passkey</span>
                                </button>
                            </div>
                            <% } else { %>
                                <div class="divide-y divide-white/5">
                                    <% passkeys.forEach((key, index)=> { %>
                                        <div class="p-6 hover:bg-white/5 transition-colors">
                                            <div class="flex justify-between items-start">
                                                <div class="flex items-start gap-4">
                                                    <!-- Іконка пристрою -->
                                                    <div
                                                        class="p-3 bg-gradient-to-br from-indigo-500/20 to-purple-500/20 rounded-xl">
                                                        <% if (key.deviceInfo && key.deviceInfo.includes('mobile')) { %>
                                                            <i class="fas fa-mobile-alt text-indigo-500 text-xl"></i>
                                                            <% } else if (key.deviceInfo &&
                                                                key.deviceInfo.includes('tablet')) { %>
                                                                <i
                                                                    class="fas fa-tablet-alt text-indigo-500 text-xl"></i>
                                                                <% } else { %>
                                                                    <i
                                                                        class="fas fa-laptop text-indigo-500 text-xl"></i>
                                                                    <% } %>
                                                    </div>

                                                    <div>
                                                        <!-- Назва ключа (можна редагувати) -->
                                                        <div class="flex items-center gap-3">
                                                            <h4 class="font-bold text-lg">
                                                                <%= key.name %>
                                                            </h4>
                                                            <button
                                                                onclick="editPasskeyName('<%= key.id %>', '<%= key.name %>')"
                                                                class="text-white/40 hover:text-white">
                                                                <i class="fas fa-pen text-xs"></i>
                                                            </button>
                                                        </div>

                                                        <!-- Інформація про ключ -->
                                                        <div class="grid grid-cols-2 gap-x-8 gap-y-2 mt-3">
                                                            <div>
                                                                <p
                                                                    class="text-[10px] text-white/30 uppercase tracking-wider">
                                                                    ID ключа</p>
                                                                <p onclick="copyToClipboard('<%= key.id %>')"
                                                                    class="font-mono text-xs text-white/60 hover:text-indigo-500 cursor-pointer transition-colors flex items-center gap-1">
                                                                    <%= key.id.slice(0, 20) %>...
                                                                        <i class="fas fa-copy text-[10px]"></i>
                                                                </p>
                                                            </div>
                                                            <div>
                                                                <p
                                                                    class="text-[10px] text-white/30 uppercase tracking-wider">
                                                                    Тип</p>
                                                                <p class="text-sm">
                                                                    <% if (key.transports &&
                                                                        key.transports.includes('hybrid')) { %>
                                                                        <span class="text-emerald-500">⚡ Hybrid</span>
                                                                        <% } else { %>
                                                                            <span class="text-blue-500">🔒
                                                                                Platform</span>
                                                                            <% } %>
                                                                </p>
                                                            </div>
                                                            <div>
                                                                <p
                                                                    class="text-[10px] text-white/30 uppercase tracking-wider">
                                                                    Створено</p>
                                                                <p class="text-sm">
                                                                    <%= new Date(key.createdAt).toLocaleString('uk-UA')
                                                                        %>
                                                                </p>
                                                            </div>
                                                            <div>
                                                                <p
                                                                    class="text-[10px] text-white/30 uppercase tracking-wider">
                                                                    Востаннє використано</p>
                                                                <p class="text-sm">
                                                                    <%= key.lastUsed ? new
                                                                        Date(key.lastUsed).toLocaleString('uk-UA')
                                                                        : 'Ніколи' %>
                                                                </p>
                                                            </div>
                                                            <div>
                                                                <p
                                                                    class="text-[10px] text-white/30 uppercase tracking-wider">
                                                                    Лічильник</p>
                                                                <p class="text-sm font-mono">
                                                                    <%= key.counter %>
                                                                </p>
                                                            </div>
                                                            <div>
                                                                <p
                                                                    class="text-[10px] text-white/30 uppercase tracking-wider">
                                                                    Пристрій</p>
                                                                <p class="text-sm">
                                                                    <%= key.deviceInfo || 'Невідомо' %>
                                                                </p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Кнопки дій -->
                                                <div class="flex gap-2">
                                                    <button onclick="renamePasskey('<%= key.id %>')"
                                                        class="p-2 hover:bg-white/10 rounded-lg transition-colors"
                                                        title="Перейменувати">
                                                        <i class="fas fa-edit text-white/40 hover:text-white"></i>
                                                    </button>
                                                    <button onclick="deletePasskey('<%= key.id %>')"
                                                        class="p-2 hover:bg-red-500/10 rounded-lg transition-colors"
                                                        title="Видалити">
                                                        <i class="fas fa-trash text-white/40 hover:text-red-500"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                                <% } %>
                    </div>

                    <!-- Інструкція з безпеки -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="glass-card">
                            <div class="p-3 bg-emerald-500/10 rounded-xl w-fit mb-4">
                                <i class="fas fa-shield text-emerald-500"></i>
                            </div>
                            <h4 class="font-bold mb-2">Біометричний захист</h4>
                            <p class="text-sm text-white/40">Кожен passkey захищений біометрією вашого пристрою (Touch
                                ID,
                                Face ID) або PIN-кодом</p>
                        </div>

                        <div class="glass-card">
                            <div class="p-3 bg-purple-500/10 rounded-xl w-fit mb-4">
                                <i class="fas fa-sync text-purple-500"></i>
                            </div>
                            <h4 class="font-bold mb-2">Синхронізація</h4>
                            <p class="text-sm text-white/40">Passkeys автоматично синхронізуються через Bitwarden між
                                вашими
                                пристроями</p>
                        </div>

                        <div class="glass-card">
                            <div class="p-3 bg-amber-500/10 rounded-xl w-fit mb-4">
                                <i class="fas fa-history text-amber-500"></i>
                            </div>
                            <h4 class="font-bold mb-2">Історія використання</h4>
                            <p class="text-sm text-white/40">Відстежуйте коли і які пристрої використовували ваші ключі
                                доступу</p>
                        </div>
                    </div>
                </div>
            </main>
    </div>

    </div>

    <!-- Модальне вікно перейменування -->
    <div id="renameModal"
        class="fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center z-50 hidden">
        <div class="bg-[#111116] border border-white/10 rounded-2xl p-8 max-w-md w-full">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-bold">Перейменувати passkey</h3>
                <button onclick="closeRenameModal()" class="w-8 h-8 rounded-lg bg-white/5 hover:bg-white/10">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <form id="renameForm" onsubmit="renamePasskeySubmit(event)">
                <input type="hidden" id="renameKeyId" name="keyId">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-white/60 mb-2">Нова назва</label>
                        <input type="text" id="renameKeyName" name="name" required
                            class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-indigo-500 transition-colors"
                            placeholder="Мій робочий ноутбук">
                    </div>

                    <div class="flex gap-3 pt-4">
                        <button type="submit"
                            class="flex-1 bg-indigo-600 hover:bg-indigo-700 py-3 rounded-xl font-medium transition-colors">
                            Зберегти
                        </button>
                        <button type="button" onclick="closeRenameModal()"
                            class="flex-1 bg-white/5 hover:bg-white/10 py-3 rounded-xl font-medium transition-colors">
                            Скасувати
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <script type="module" src="/frontend/admin-passkeys.js"></script>

    <style>
        .nav-link {
            @apply flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all;
        }

        .nav-link:not(.active) {
            @apply text-white/40 hover:text-white hover:bg-white/5;
        }

        .nav-link.active {
            @apply bg-indigo-600 text-white shadow-lg shadow-indigo-600/20;
        }

        .glass-card {
            @apply bg-[#111116] rounded-2xl p-6 border border-white/5 backdrop-blur-sm;
        }
    </style>
    <%- include('layout/admin-main') %>
</body>

</html>