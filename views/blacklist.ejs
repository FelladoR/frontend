<!-- views/blacklist.ejs -->
<!DOCTYPE html>
<html lang="uk">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AntiLink Admin | Чорний список</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/styles/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
</head>

<body class="bg-[#0b0b0e] text-[#e2e2e4] font-sans selection:bg-indigo-500/30">
    <div id="app-data" data-user='<%= JSON.stringify(user) %>' data-users='<%= JSON.stringify(users) %>'
        data-current-role='<%= currentUserRole %>' style="display: none;"></div>

    <div id="app">
        <%- include('layout/admin-side') %>

            <!-- Головний контент -->
            <main class="flex-1 flex flex-col">
                <header
                    class="h-20 bg-[#111116]/50 backdrop-blur-xl border-b border-white/5 flex items-center justify-between px-10 sticky top-0 z-50">
                    <div class="flex items-center gap-4">
                        <div
                            class="w-2 h-2 rounded-full bg-indigo-500 shadow-[0_0_10px_rgba(99,102,241,0.8)] animate-pulse">
                        </div>
                        <span class="text-sm font-medium text-white/70">Вітаємо, <span class="text-white font-bold">{{
                                user.username }}</span></span>
                    </div>
                    <div class="flex items-center gap-6">
                        <div v-if="user.hasPasskey"
                            class="flex items-center gap-2 px-3 py-1.5 bg-emerald-500/10 border border-emerald-500/20 rounded-full">
                            <i class="fas fa-check-double text-emerald-500 text-[10px]"></i>
                            <span
                                class="text-[10px] font-black text-emerald-500 uppercase tracking-widest">Secured</span>
                        </div>
                        <a href="/logout"
                            class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center hover:bg-red-500/20 hover:text-red-500 transition-all border border-white/5">
                            <i class="fas fa-power-off text-sm"></i>
                        </a>
                    </div>
                </header>

                <div class="p-10 space-y-8">
                    <!-- Заголовок -->
                    <div class="flex justify-between items-center">
                        <div>
                            <h1 class="text-3xl font-black tracking-tight flex items-center gap-3">
                                <i class="fas fa-ban text-red-500"></i>
                                Чорний список
                            </h1>
                            <p class="text-white/40 text-sm mt-1">Користувачі з попередженнями та порушеннями</p>
                        </div>
                        <div class="flex gap-3">
                            <button v-if="currentUserRole === 'superadmin' || currentUserRole === 'admin'"
                                @click="openWarnModal"
                                class="bg-red-600 hover:bg-red-700 px-5 py-3 rounded-xl font-medium flex items-center gap-2 transition-all">
                                <i class="fas fa-exclamation-triangle"></i>
                                <span>Видати попередження</span>
                            </button>
                        </div>
                    </div>

                    <!-- Статистика -->
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                        <div class="glass-card group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-white/40 text-[11px] font-bold uppercase tracking-widest">
                                        Користувачів</p>
                                    <h3 class="text-3xl font-black mt-1 tracking-tight">{{ users.length }}</h3>
                                </div>
                                <div
                                    class="p-3 bg-red-500/10 rounded-2xl text-red-500 group-hover:scale-110 transition-transform">
                                    <i class="fas fa-users-slash"></i>
                                </div>
                            </div>
                        </div>

                        <div class="glass-card group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-white/40 text-[11px] font-bold uppercase tracking-widest">Всього
                                        попереджень</p>
                                    <h3 class="text-3xl font-black mt-1 tracking-tight">{{ totalWarnings }}</h3>
                                </div>
                                <div
                                    class="p-3 bg-yellow-500/10 rounded-2xl text-yellow-500 group-hover:scale-110 transition-transform">
                                    <i class="fas fa-exclamation-triangle"></i>
                                </div>
                            </div>
                        </div>

                        <div class="glass-card group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-white/40 text-[11px] font-bold uppercase tracking-widest">Середнє</p>
                                    <h3 class="text-3xl font-black mt-1 tracking-tight">{{ avgWarnings }}</h3>
                                </div>
                                <div
                                    class="p-3 bg-orange-500/10 rounded-2xl text-orange-500 group-hover:scale-110 transition-transform">
                                    <i class="fas fa-chart-line"></i>
                                </div>
                            </div>
                        </div>

                        <div class="glass-card group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-white/40 text-[11px] font-bold uppercase tracking-widest">Сьогодні
                                    </p>
                                    <h3 class="text-3xl font-black mt-1 tracking-tight">{{ todayWarnings }}</h3>
                                </div>
                                <div
                                    class="p-3 bg-cyan-500/10 rounded-2xl text-cyan-500 group-hover:scale-110 transition-transform">
                                    <i class="fas fa-calendar-day"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Фільтри -->
                    <div class="flex gap-3">
                        <button v-for="option in filterOptions" :key="option.value" @click="setFilter(option.value)"
                            :class="['filter-btn', { active: currentFilter === option.value }]">
                            {{ option.label }}
                            <span class="ml-2 text-xs bg-white/10 px-2 py-0.5 rounded-full">{{
                                getFilterCount(option.value) }}</span>
                        </button>
                    </div>

                    <!-- Пошук -->
                    <div class="relative">
                        <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-white/20"></i>
                        <input type="text" v-model="searchQuery" placeholder="Пошук за ID користувача..."
                            class="w-full bg-white/5 border border-white/10 rounded-xl pl-10 pr-4 py-3 focus:outline-none focus:border-indigo-500 transition-colors">
                    </div>

                    <!-- Таблиця користувачів з пагінацією -->
                    <div class="glass-card !p-0 overflow-hidden border-white/10">
                        <div class="overflow-x-auto">
                            <table class="w-full">
                                <thead class="bg-white/5 border-b border-white/5">
                                    <tr>
                                        <th
                                            class="text-left py-4 px-6 text-[10px] font-black text-white/40 uppercase tracking-widest">
                                            Користувач</th>
                                        <th
                                            class="text-left py-4 px-6 text-[10px] font-black text-white/40 uppercase tracking-widest">
                                            ID</th>
                                        <th
                                            class="text-left py-4 px-6 text-[10px] font-black text-white/40 uppercase tracking-widest">
                                            Попереджень</th>
                                        <th
                                            class="text-left py-4 px-6 text-[10px] font-black text-white/40 uppercase tracking-widest">
                                            Останнє попередження</th>
                                        <th
                                            class="text-left py-4 px-6 text-[10px] font-black text-white/40 uppercase tracking-widest">
                                            Причина</th>
                                        <th
                                            class="text-left py-4 px-6 text-[10px] font-black text-white/40 uppercase tracking-widest">
                                            Дії</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-white/5">
                                    <tr v-for="user in paginatedUsers" :key="user._id"
                                        class="hover:bg-white/5 transition-colors">
                                        <td class="py-4 px-6">
                                            <div class="flex items-center gap-3">
                                                <div
                                                    class="w-8 h-8 rounded-full bg-gradient-to-br from-red-500 to-orange-600 flex items-center justify-center text-white font-bold text-sm">
                                                    {{ user._id.slice(-4) }}
                                                </div>
                                                <div>
                                                    <p class="font-medium">Користувач {{ user._id.slice(0, 8) }}...</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="py-4 px-6 font-mono text-sm text-white/60">{{ user._id.slice(0, 16)
                                            }}...</td>
                                        <td class="py-4 px-6">
                                            <span :class="[
                                                'px-3 py-1 rounded-full text-[10px] font-bold',
                                                user.warns === 0 ? 'bg-green-500/20 text-green-500' :
                                                user.warns < 3 ? 'bg-yellow-500/20 text-yellow-500' :
                                                'bg-red-500/20 text-red-500'
                                            ]">
                                                {{ user.warns }} попереджень
                                            </span>
                                        </td>
                                        <td class="py-4 px-6 text-sm text-white/60">
                                            {{ getLastWarning(user) ? formatDate(getLastWarning(user).timestamp) :
                                            'Немає' }}
                                        </td>
                                        <td class="py-4 px-6">
                                            <div class="max-w-xs">
                                                <p class="text-sm">{{ getLastWarning(user)?.reason || '-' }}</p>
                                            </div>
                                        </td>
                                        <td class="py-4 px-6">
                                            <div class="flex items-center gap-2">
                                                <button @click="viewUserHistory(user)"
                                                    class="p-2 hover:bg-blue-500/10 rounded-lg transition-colors"
                                                    title="Історія">
                                                    <i class="fas fa-history text-white/40 hover:text-blue-500"></i>
                                                </button>
                                                <button
                                                    v-if="currentUserRole === 'superadmin' || currentUserRole === 'admin'"
                                                    @click="removeWarning(user)"
                                                    class="p-2 hover:bg-green-500/10 rounded-lg transition-colors"
                                                    title="Зняти попередження">
                                                    <i
                                                        class="fas fa-check-circle text-white/40 hover:text-green-500"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr v-if="paginatedUsers.length === 0">
                                        <td colspan="6" class="py-12 text-center text-white/40">
                                            <i class="fas fa-inbox text-4xl mb-3 block"></i>
                                            <p>Немає користувачів</p>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Пагінація -->
                        <div class="bg-white/5 px-6 py-4 border-t border-white/5 flex justify-between items-center">
                            <p class="text-sm text-white/40">
                                Показано <span class="text-white font-medium">{{ paginationStart }}-{{ paginationEnd
                                    }}</span> з <span class="text-white font-medium">{{ filteredUsers.length }}</span>
                                користувачів
                            </p>
                            <div class="flex gap-2">
                                <button @click="prevPage" :disabled="currentPage === 1"
                                    class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center hover:bg-white/10 transition-colors disabled:opacity-30">
                                    <i class="fas fa-chevron-left"></i>
                                </button>
                                <button v-for="page in displayedPages" :key="page" @click="goToPage(page)" :class="['w-10 h-10 rounded-xl flex items-center justify-center transition-colors', 
                                             currentPage === page ? 'bg-indigo-600' : 'bg-white/5 hover:bg-white/10']">
                                    {{ page }}
                                </button>
                                <button @click="nextPage" :disabled="currentPage === totalPages"
                                    class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center hover:bg-white/10 transition-colors disabled:opacity-30">
                                    <i class="fas fa-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
    </div>

    <!-- Модальне вікно видачі попередження -->
    <div v-show="showWarnModal"
        class="fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center z-50">
        <div class="bg-[#111116] border border-white/10 rounded-2xl p-8 max-w-md w-full">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-bold flex items-center gap-2">
                    <i class="fas fa-exclamation-triangle text-yellow-500"></i>
                    Видати попередження
                </h3>
                <button @click="closeWarnModal" class="w-8 h-8 rounded-lg bg-white/5 hover:bg-white/10">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <form @submit.prevent="submitWarn">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-white/60 mb-2">ID користувача</label>
                        <input type="text" v-model="warnForm.userId" required
                            class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-yellow-500 transition-colors"
                            placeholder="558945911980556288">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-white/60 mb-2">Причина</label>
                        <textarea v-model="warnForm.reason" required rows="3"
                            class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-yellow-500 transition-colors"
                            placeholder="Опишіть причину попередження..."></textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-white/60 mb-2">Докази (посилання)</label>
                        <input type="url" v-model="warnForm.proofs"
                            class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-yellow-500 transition-colors"
                            placeholder="https://...">
                    </div>

                    <div class="flex gap-3 pt-4">
                        <button type="submit" :disabled="warnLoading"
                            class="flex-1 bg-yellow-600 hover:bg-yellow-700 py-3 rounded-xl font-medium transition-colors disabled:opacity-50">
                            {{ warnLoading ? 'Видача...' : 'Видати попередження' }}
                        </button>
                        <button type="button" @click="closeWarnModal"
                            class="flex-1 bg-white/5 hover:bg-white/10 py-3 rounded-xl font-medium transition-colors">
                            Скасувати
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>


    <script type="module" src="/frontend/blacklist.js"></script>

    <style>
        .nav-link {
            @apply flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all;
        }

        .nav-link:not(.active) {
            @apply text-white/40 hover:text-white hover:bg-white/5;
        }

        .nav-link.active {
            @apply bg-indigo-600 text-white shadow-lg shadow-indigo-600/20;
        }

        .glass-card {
            @apply bg-[#111116] rounded-2xl p-6 border border-white/5 backdrop-blur-sm;
        }

        .filter-btn {
            @apply px-4 py-2 rounded-lg text-sm font-medium transition-colors;
        }

        .filter-btn:not(.active) {
            @apply bg-white/5 text-white/60 hover:bg-white/10;
        }

        .filter-btn.active {
            @apply bg-indigo-600 text-white;
        }
    </style>
    <%- include('layout/admin-main') %>
</body>

</html>